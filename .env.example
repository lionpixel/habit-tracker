# HabitDB — Environment Variables
# Copy this file to .env.local and fill in the values

# App
NEXT_PUBLIC_APP_NAME=HabitDB
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics (opcional)
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Supabase (Storage para imagens dos Sonhos + futura migração de dados)
# 1. Crie um projeto em https://supabase.com
# 2. Crie um bucket público chamado "dreams" no Storage
# 3. Cole as credenciais abaixo
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# SQL para criar a tabela dreams (rodar no Supabase SQL Editor):
# CREATE TABLE dreams (
#   id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
#   user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,
#   title TEXT NOT NULL,
#   description TEXT,
#   category TEXT NOT NULL,
#   image_url TEXT,
#   emotional_reason TEXT,
#   execution_plan TEXT,
#   progress INT DEFAULT 0,
#   status TEXT DEFAULT 'active',
#   financial_target NUMERIC,
#   financial_current NUMERIC,
#   target_date DATE,
#   created_at TIMESTAMPTZ DEFAULT NOW(),
#   updated_at TIMESTAMPTZ DEFAULT NOW()
# );
# ALTER TABLE dreams ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "Own data only" ON dreams USING (auth.uid() = user_id);
# -- Storage RLS: bucket "dreams" deve ser público (Public bucket)

# Auth (futuro)
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000
