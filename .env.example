# HabitDB — Environment Variables
# Copy this file to .env.local and fill in the values
#
# LEGENDA DE SEGURANÇA:
#   ✅ NEXT_PUBLIC_  → seguro expor no browser (URL pública, anon key protegida por RLS)
#   🔒 sem prefixo  → server-side only — NUNCA colocar NEXT_PUBLIC_ nessas variáveis

# ─── AUTENTICAÇÃO (NextAuth / Auth.js) ────────────────────────────────────────
# 🔒 Gerar com: npx auth secret
AUTH_SECRET=

# 🔒 Google Cloud Console → Credenciais → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ✅ URL base do app (sem barra final) — necessário para OAuth redirects
NEXTAUTH_URL=http://localhost:3000
# Produção: NEXTAUTH_URL=https://habitdb.vercel.app

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# ✅ Settings → API → Project URL (URL pública, sem risco expor no browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# ✅ Settings → API → anon/public key (protegida por RLS — seguro no browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 🔒 Settings → API → service_role key — bypassa RLS, acesso total ao banco.
# Usado por src/lib/supabase/admin.ts (createSupabaseAdmin).
# NUNCA usar em componentes ou com NEXT_PUBLIC_. Na Vercel: NÃO marque "Expose to browser".
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# SQL para criar Storage policy (rodar no Supabase SQL Editor):
# -- Bucket "dreams" deve ser público para leitura de URLs
# -- Policy de upload: só o próprio usuário pode fazer upload
# CREATE POLICY "usuario acessa proprios arquivos"
# ON storage.objects FOR ALL
# USING (auth.uid()::text = (storage.foldername(name))[1]);

# ─── ANTHROPIC (Claude API) ───────────────────────────────────────────────────
# 🔒 console.anthropic.com → API Keys
# NUNCA usar NEXT_PUBLIC_ aqui — a chave é chamada via /api/insights no servidor.
# Na Vercel: NÃO marque "Expose to browser" para esta variável.
ANTHROPIC_API_KEY=sk-ant-...

# ─── OPENAI (GPT API) ─────────────────────────────────────────────────────────
# 🔒 platform.openai.com → API Keys
# NUNCA usar NEXT_PUBLIC_ aqui — chamada server-side via /api/openai/*
# Modelos usados: gpt-4o-mini (insights rápidos), gpt-4o (relatórios)
# Na Vercel: NÃO marque "Expose to browser".
OPENAI_API_KEY=sk-proj-...

# ─── APP ──────────────────────────────────────────────────────────────────────
# ✅ Nome e URL públicos do app
NEXT_PUBLIC_APP_NAME=HabitDB
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── ANALYTICS (opcional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── CHECKLIST VERCEL (vercel.com → Project → Settings → Environment Variables) ──
# Variáveis obrigatórias em produção:
#   AUTH_SECRET                   → Expose to browser: NÃO
#   GOOGLE_CLIENT_ID              → Expose to browser: NÃO
#   GOOGLE_CLIENT_SECRET          → Expose to browser: NÃO
#   NEXTAUTH_URL                  → Expose to browser: NÃO
#   NEXT_PUBLIC_SUPABASE_URL      → Expose to browser: SIM (é NEXT_PUBLIC_)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY → Expose to browser: SIM (é NEXT_PUBLIC_)
#   SUPABASE_SERVICE_ROLE_KEY     → Expose to browser: NÃO ← CRÍTICO (bypassa RLS)
#   ANTHROPIC_API_KEY             → Expose to browser: NÃO ← CRÍTICO
#   NEXT_PUBLIC_APP_URL           → Expose to browser: SIM (é NEXT_PUBLIC_)
